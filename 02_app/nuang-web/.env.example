# Local app origin
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Public Supabase values.
# These two are safe to expose to the browser, but still keep real project values out of chat.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values. Never expose these in browser code or screenshots.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Google and Kakao OAuth credentials are configured in the Supabase dashboard.
# Naver needs a custom OAuth/OIDC bridge or a separate callback implementation.
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

# Server-only secrets for future share tokens and encrypted contact fields.
SHARE_TOKEN_PEPPER=
FIELD_ENCRYPTION_KEY=
ADMIN_BOOTSTRAP_EMAILS=
