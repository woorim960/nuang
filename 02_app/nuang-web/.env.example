# 로컬 개발 환경에서 사용하는 앱 주소입니다.
# Next.js 앱이 로컬에서 실행되는 기본 주소입니다.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000


# 브라우저에 노출되어도 되는 Supabase 공개 설정값입니다.
# 단, 실제 프로젝트 값은 보안상 채팅이나 캡처 화면에 노출하지 않는 것이 좋습니다.

# Supabase 프로젝트 URL입니다.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 익명 공개 키입니다.
# 클라이언트에서 Supabase에 접근할 때 사용됩니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# 서버에서만 사용해야 하는 값입니다.
# 절대 브라우저 코드, 프론트엔드 화면, 스크린샷에 노출하면 안 됩니다.

# Supabase 관리자 권한 키입니다.
# 데이터베이스에 강한 권한으로 접근할 수 있으므로 절대 외부에 노출하면 안 됩니다.
SUPABASE_SERVICE_ROLE_KEY=

# 데이터베이스 직접 연결 주소입니다.
# 서버에서 DB에 연결할 때 사용합니다.
DATABASE_URL=


# Google 및 Kakao OAuth 로그인 정보는 Supabase 대시보드에서 설정합니다.
# 이 .env 파일에는 별도로 입력하지 않습니다.

# Naver 로그인은 Supabase 기본 OAuth만으로 바로 처리하기 어렵습니다.
# 별도의 OAuth/OIDC 브릿지 또는 직접 구현한 콜백 처리가 필요합니다.

# Naver OAuth 클라이언트 ID입니다.
NAVER_OAUTH_CLIENT_ID=

# Naver OAuth 클라이언트 시크릿입니다.
# 서버에서만 사용해야 하며 외부에 노출하면 안 됩니다.
NAVER_OAUTH_CLIENT_SECRET=


# 향후 공유 토큰 생성 및 연락처 필드 암호화에 사용할 서버 전용 비밀값입니다.

# 공유 링크나 초대 토큰을 더 안전하게 만들기 위한 추가 비밀값입니다.
SHARE_TOKEN_PEPPER=

# 연락처 같은 민감한 필드를 암호화할 때 사용할 키입니다.
FIELD_ENCRYPTION_KEY=

# 최초 관리자 계정으로 등록할 이메일 목록입니다.
# 여러 명이면 쉼표로 구분해서 입력할 수 있습니다.
ADMIN_BOOTSTRAP_EMAILS=